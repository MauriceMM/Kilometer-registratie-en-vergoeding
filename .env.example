# Kopieer dit bestand naar .env en pas de waarden aan
# NOOIT .env committen naar git!

# App-wachtwoord voor de inlogpagina
APP_PASSWORD=kies-een-sterk-wachtwoord

# JWT-geheime sleutel (gebruik: openssl rand -hex 32)
SECRET_KEY=vervang-met-output-van-openssl-rand-hex-32

# Database locatie (niet wijzigen tenzij je weet wat je doet)
DATABASE_URL=sqlite:////app/data/kmv.db
